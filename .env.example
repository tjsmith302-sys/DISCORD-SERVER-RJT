# ---- Discord ----
# Create at https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here
# Optional: restrict slash command registration to one guild for fast iteration
DISCORD_GUILD_ID=

# ---- OpenAI ----
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o

# ---- Supabase ----
# Get from Supabase dashboard > Project Settings > API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Runtime tuning ----
# Silence gap (ms) that closes a speaker's utterance and triggers transcription
SILENCE_GAP_MS=1500
# Max single utterance length (ms) before forced flush
MAX_UTTERANCE_MS=30000
# Log level: debug | info | warn | error
LOG_LEVEL=info
